def natural_sort_key(text: str):
    return [int(s) if s.isdigit() else s.lower() for s in re.split(r"(\d+)", text)]


def safe_float(s: str):
    s = (s or "").strip()
    if s == "":
        return None
    try:
        return float(s)
    except ValueError:
        return "INVALID"


def safe_int(s: str):
    s = (s or "").strip()
    if s == "":
        return None
    try:
        return int(float(s))
    except ValueError:
        return "INVALID"


